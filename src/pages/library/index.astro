---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SubjectCard from '../../components/SubjectCard.astro';
import PostCard from '../../components/PostCard.astro';
import RecentUpdateList from '../../components/RecentUpdateList.astro';
import { byPublishedDesc, getLessonPath, getPostPath } from '../../lib/content';
const subjects = (await getCollection('subjects')).sort((a, b) => a.data.order - b.data.order);
const lessons = await getCollection('lessons', ({ data }) => !data.draft);
const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(byPublishedDesc);
const updates = [...lessons.map((lesson) => ({ href: getLessonPath(lesson), title: lesson.data.title, description: lesson.data.description, date: lesson.data.updated, kind: 'Lesson', accent: subjects.find((subject) => subject.data.slug === lesson.data.subject)?.data.accent })), ...posts.map((post) => ({ href: getPostPath(post), title: post.data.title, description: post.data.description, date: post.data.updated ?? post.data.published, kind: 'Post', accent: 'var(--coral)' }))].sort((a, b) => b.date.valueOf() - a.date.valueOf());
---
<BaseLayout title="Library — Commonplace" description="Every subject, lesson, and article in the Commonplace library.">
  <header class="page-header page-shell"><span class="eyebrow">All content</span><h1 class="display-title">The library</h1><p class="lede">Two ways into the same collection: follow a subject to learn step by step, or open a post for one complete idea.</p></header>
  <section class="section page-shell"><div class="section-heading"><div><span class="eyebrow">Subject spaces</span><h2 class="section-title">Structured learning</h2></div><a class="text-link" href="/notes/">All subjects →</a></div><div class="card-grid">{subjects.map((subject) => <SubjectCard subject={subject} lessonCount={lessons.filter((lesson) => lesson.data.subject === subject.data.slug).length} />)}</div></section>
  <section class="section--tight page-shell"><div class="section-heading"><div><span class="eyebrow">Long-form</span><h2 class="section-title">Articles & essays</h2></div><a class="text-link" href="/posts/">All posts →</a></div><div class="card-grid">{posts.map((post) => <PostCard post={post} />)}</div></section>
  <section class="section page-shell"><div class="section-heading"><div><span class="eyebrow">Chronological view</span><h2 class="section-title">Every recent update</h2></div></div><RecentUpdateList updates={updates} /></section>
</BaseLayout>
