---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SubjectCard from '../../components/SubjectCard.astro';
import PostCard from '../../components/PostCard.astro';
import RecentUpdateList from '../../components/RecentUpdateList.astro';
import { byPublishedDesc, getLessonPath, getPostPath } from '../../lib/content';
const subjects = (await getCollection('subjects')).sort((a, b) => a.data.order - b.data.order);
const lessons = await getCollection('lessons', ({ data }) => !data.draft);
const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(byPublishedDesc);
const updates = [...lessons.map((lesson) => ({ href: getLessonPath(lesson), title: lesson.data.title, description: lesson.data.description, date: lesson.data.updated, kind: lesson.data.subject, accent: 'var(--teal)' })), ...posts.map((post) => ({ href: getPostPath(post), title: post.data.title, description: post.data.description, date: post.data.updated ?? post.data.published, kind: 'Post', accent: 'var(--coral)' }))].sort((a, b) => b.date.valueOf() - a.date.valueOf());
---
<BaseLayout title="Library — Oli's Blog" description="All articles and notes from Oli's Blog.">
  <header class="page-header page-shell"><h1 class="display-title">LIBRARY</h1></header>
  {subjects.length > 0 && <section class="section page-shell"><div class="section-heading"><div><h2 class="section-title">Notes</h2></div><a class="text-link" href="/notes/">All notes →</a></div><div class="card-grid">{subjects.map((subject) => <SubjectCard subject={subject} lessons={lessons.filter((lesson) => lesson.data.subject === subject.data.slug)} />)}</div></section>}
  <section class="section--tight page-shell"><div class="section-heading"><div><h2 class="section-title">Posts</h2></div><a class="text-link" href="/posts/">All posts →</a></div><div class="card-grid">{posts.map((post) => <PostCard post={post} />)}</div></section>
  <section class="section page-shell"><div class="section-heading"><div><span class="eyebrow">Latest Posts</span><h2 class="section-title">最近更新</h2></div></div><RecentUpdateList updates={updates} /></section>
</BaseLayout>
