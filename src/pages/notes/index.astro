---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SubjectCard from '../../components/SubjectCard.astro';
const subjects = (await getCollection('subjects')).sort((a, b) => a.data.order - b.data.order);
const lessons = await getCollection('lessons', ({ data }) => !data.draft);
---
<BaseLayout title="Notes — Olí's Blog" description="Structured subject notes from Olí's Blog.">
  <header class="page-header page-shell"><span class="eyebrow">Learning spaces</span><h1 class="display-title">Subjects</h1><p class="lede">Each subject has its own map. Sections and modules come from content metadata, so every field can develop a structure that fits it.</p></header>
  <section class="section page-shell">{subjects.length > 0 ? <div class="card-grid">{subjects.map((subject) => <SubjectCard subject={subject} lessonCount={lessons.filter((lesson) => lesson.data.subject === subject.data.slug).length} />)}</div> : <div class="empty-state"><strong>notes/ is empty for now.</strong><p>範例筆記已移除；之後新增的主題筆記會出現在這裡。</p></div>}</section>
</BaseLayout>
