---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { byPublishedDesc } from '../../lib/content';

export async function getStaticPaths() {
  const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(byPublishedDesc);
  return posts.map((post, index) => ({ params: { slug: post.id }, props: { post, previous: posts[index + 1], next: posts[index - 1] } }));
}
const { post, previous, next } = Astro.props;
const { Content, headings } = await render(post);
---
<PostLayout post={post} headings={headings} previous={previous} next={next}><Content /></PostLayout>
