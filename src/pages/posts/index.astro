---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { byPublishedDesc } from '../../lib/content';
const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(byPublishedDesc);
---
<BaseLayout title="Posts — Oli's Blog" description="Oli's articles, course reflections, technical notes, and experiences.">
  <header class="page-header page-shell"><h1 class="display-title">POSTS</h1></header>
  <section class="section page-shell"><div class="posts-list">{posts.map((post) => <PostCard post={post} />)}</div></section>
</BaseLayout>
<style>.posts-list { display: grid; grid-template-columns: minmax(0, 1fr); gap: 1rem; }</style>
