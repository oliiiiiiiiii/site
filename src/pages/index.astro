---
import { getCollection } from 'astro:content';
import HomeLayout from '../layouts/HomeLayout.astro';
import DashboardCard from '../components/DashboardCard.astro';
import PostCard from '../components/PostCard.astro';
import RecentUpdateList from '../components/RecentUpdateList.astro';
import SubjectCard from '../components/SubjectCard.astro';
import { byPublishedDesc, getLessonPath, getPostPath } from '../lib/content';

const subjects = (await getCollection('subjects')).sort((a, b) => a.data.order - b.data.order);
const lessons = (await getCollection('lessons', ({ data }) => !data.draft));
const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(byPublishedDesc);
const featuredSubjects = subjects.filter((subject) => subject.data.featured);
const featuredPost = posts.find((post) => post.data.featured) ?? posts[0];
const updates = [
  ...lessons.map((lesson) => ({ href: getLessonPath(lesson), title: lesson.data.title, description: lesson.data.description, date: lesson.data.updated, kind: 'Lesson', accent: subjects.find((subject) => subject.data.slug === lesson.data.subject)?.data.accent })),
  ...posts.map((post) => ({ href: getPostPath(post), title: post.data.title, description: post.data.description, date: post.data.updated ?? post.data.published, kind: 'Post', accent: 'var(--coral)' })),
].sort((a, b) => b.date.valueOf() - a.date.valueOf()).slice(0, 5);
---
<HomeLayout>
  <section class="intro-band"><div class="page-shell intro-grid"><div><span class="eyebrow">Why this exists</span><h2 class="section-title">A home for finished essays and unfinished understanding.</h2><p class="lede">Posts hold complete ideas. Subject spaces hold lessons that keep evolving. Together they make a personal library that is useful now and easy to grow later.</p></div><div class="dashboard-grid"><DashboardCard label="Subjects" value={subjects.length} detail="Independent learning maps" tone="teal" /><DashboardCard label="Lessons" value={lessons.length} detail="Connected study notes" tone="coral" /><DashboardCard label="Articles" value={posts.length} detail="Long-form pieces" tone="gold" /></div></div></section>

  <section class="section page-shell"><div class="section-heading"><div><span class="eyebrow">Featured subjects</span><h2 class="section-title">Follow a thread of curiosity</h2></div><a class="text-link" href="/notes/">See all subjects →</a></div><div class="card-grid">{featuredSubjects.map((subject) => <SubjectCard subject={subject} lessonCount={lessons.filter((lesson) => lesson.data.subject === subject.data.slug).length} />)}</div></section>

  {featuredPost && <section class="section page-shell"><div class="section-heading"><div><span class="eyebrow">Featured article</span><h2 class="section-title">One idea, explored fully</h2></div><a class="text-link" href="/posts/">Browse all posts →</a></div><div class="featured-post"><PostCard post={featuredPost} featured /></div></section>}

  <section class="section page-shell updates-section"><div class="section-heading"><div><span class="eyebrow">Recently tended</span><h2 class="section-title">What changed lately</h2></div><a class="text-link" href="/library/">Open library →</a></div><RecentUpdateList updates={updates} /></section>

  <section class="personal-note page-shell"><span class="note-mark" aria-hidden="true">“</span><div><span class="eyebrow">A note from Oli</span><p>I’m building this as a place to think in public: precise enough to be useful, loose enough to keep changing.</p><div class="social-links"><a href="https://github.com" rel="noreferrer">GitHub ↗</a><a href="/about/">More about me →</a></div></div></section>
</HomeLayout>

<style>
  .intro-band { padding-block: clamp(4rem, 8vw, 7rem); border-block: 1px solid var(--line); background: var(--surface-2); }
  .intro-grid { display: grid; grid-template-columns: minmax(0, 1fr) minmax(480px, .9fr); align-items: center; gap: clamp(3rem, 7vw, 7rem); }
  .intro-grid .lede { margin: 1.2rem 0 0; }.dashboard-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: .8rem; }
  .featured-post :global(.post-card) { width: 100%; }.updates-section { padding-top: 2rem; }
  .personal-note { margin-top: clamp(4rem, 8vw, 7rem); padding: clamp(2rem, 5vw, 4rem); display: grid; grid-template-columns: auto 1fr; gap: 2rem; color: #f8f2e8; border-radius: var(--radius-lg); background: #192936; box-shadow: var(--shadow-md); }
  .note-mark { color: var(--coral); font-family: var(--font-serif); font-size: 7rem; line-height: .7; }.personal-note p { max-width: 800px; margin: .9rem 0 1.3rem; font-family: var(--font-serif); font-size: clamp(1.5rem, 3vw, 2.3rem); line-height: 1.3; }
  .social-links { display: flex; gap: 1.2rem; }.social-links a { color: #8ccbc6; font-size: .8rem; font-weight: 800; text-underline-offset: .2em; }
  @media (max-width: 1100px) { .intro-grid { grid-template-columns: 1fr; } }
  @media (max-width: 680px) { .dashboard-grid { grid-template-columns: 1fr; }.personal-note { grid-template-columns: 1fr; }.note-mark { font-size: 4rem; } }
</style>
