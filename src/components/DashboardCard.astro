---
interface Props { label: string; value: string | number; detail: string; tone?: 'teal' | 'coral' | 'gold'; }
const { label, value, detail, tone = 'teal' } = Astro.props;
---
<article class:list={['dashboard-card', tone]}><span>const {label.toLowerCase()} =</span><strong>{value}<i>;</i></strong><p>{`// ${detail}`}</p></article>
<style>
  .dashboard-card { min-height: 180px; padding: 1.35rem; display: flex; flex-direction: column; border: 1px solid var(--line); border-radius: var(--radius-sm); background: var(--surface); box-shadow: var(--shadow-sm); }
  span { font-family: var(--font-mono); font-size: .62rem; font-weight: 700; }
  strong { margin: auto 0 .2rem; font-family: var(--font-mono); font-size: 3.2rem; font-weight: 750; line-height: 1; }strong i { color: var(--muted); font-style: normal; }
  p { margin: 0; color: var(--muted); font-family: var(--font-mono); font-size: .64rem; }
  .teal span, .teal strong { color: var(--teal); }.coral span, .coral strong { color: var(--coral); }.gold span, .gold strong { color: #9a6a13; }
</style>
