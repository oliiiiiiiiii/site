---
import type { CollectionEntry } from 'astro:content';
import { getLessonPath, groupLessonsByModule } from '../lib/content';
interface Props { lessons: CollectionEntry<'lessons'>[]; }
const { lessons } = Astro.props;
const groups = groupLessonsByModule(lessons);
---
<div class="module-list">{groups.map((group) => <section>{group.module && <h4>{group.module}</h4>}<ol>{group.lessons.map((lesson) => <li><a href={getLessonPath(lesson)}><span>{lesson.data.title}</span><small>{lesson.data.description}</small></a></li>)}</ol></section>)}</div>
<style>
  .module-list { display: grid; gap: 1.1rem; }
  section { padding: 1.3rem; border: 1px solid var(--line); border-radius: var(--radius-sm); background: var(--surface); }
  h4 { margin: 0 0 .9rem; color: var(--muted); font-family: var(--font-mono); font-size: .62rem; letter-spacing: .06em; text-transform: lowercase; }
  ol { padding: 0; margin: 0; display: grid; gap: .25rem; list-style: none; }
  a { padding: .7rem .75rem; display: block; border-radius: .5rem; text-decoration: none; }a:hover { background: var(--surface-2); }
  a span, a small { display: block; }a span { color: var(--ink); font-family: var(--font-sans); font-weight: 700; }a small { margin-top: .2rem; color: var(--muted); font-size: .73rem; }
</style>
