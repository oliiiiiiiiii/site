---
import type { CollectionEntry } from 'astro:content';
import { formatDate, getPostPath } from '../lib/content';
import TagList from './TagList.astro';
interface Props { post: CollectionEntry<'posts'>; }
const { post } = Astro.props;
---
<a class="post-card" href={getPostPath(post)}>
  <div class="post-copy"><div class="post-date"><time datetime={post.data.published.toISOString()}>{formatDate(post.data.published)}</time></div><h3>{post.data.title}</h3><p>{post.data.description}</p><TagList tags={post.data.tags} /><span class="read-link">Read article <span aria-hidden="true">→</span></span></div>
</a>
<style>
  .post-card { overflow: hidden; display: grid; grid-template-rows: 1fr; color: var(--ink); border: 1px solid var(--line); border-radius: var(--radius-sm); background: var(--surface); box-shadow: var(--shadow-sm); text-decoration: none; transition: transform .2s ease, box-shadow .2s ease; }
  .post-card:hover { transform: translate(-3px, -3px); box-shadow: 6px 6px 0 color-mix(in srgb, var(--coral) 22%, transparent); }
  .post-copy { padding: 1.5rem; display: flex; flex-direction: column; }
  .post-date { display: flex; justify-content: space-between; color: var(--muted); font-family: var(--font-mono); font-size: .62rem; font-weight: 700; }
  h3 { margin: .8rem 0 .6rem; font-family: var(--font-sans); font-size: 1.55rem; font-weight: 740; letter-spacing: -.025em; line-height: 1.15; }
  .post-card:hover h3 { color: var(--coral); }
  p { margin: 0 0 1.2rem; color: var(--ink-soft); font-size: .88rem; line-height: 1.65; }
  .read-link { margin-top: auto; padding-top: 1.3rem; color: var(--coral); font-family: var(--font-mono); font-size: .7rem; font-weight: 800; }
</style>
