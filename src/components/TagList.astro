---
interface Props { tags: string[]; }
const { tags } = Astro.props;
---
<ul class="tag-list" aria-label="Tags">{tags.map((tag) => <li>{tag}</li>)}</ul>
<style>
  .tag-list { padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: .45rem; list-style: none; }
  li { padding: .28rem .55rem; color: var(--coral); border: 1px solid color-mix(in srgb, var(--coral) 36%, var(--line)); border-radius: var(--radius-sm); background: var(--coral-soft); font-family: var(--font-mono); font-size: .61rem; font-weight: 750; }
</style>
