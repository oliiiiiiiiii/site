---
interface Update { href: string; title: string; description: string; date: Date; kind: string; accent?: string; }
interface Props { updates: Update[]; }
const { updates } = Astro.props;
const formatter = new Intl.DateTimeFormat('en', { month: 'short', day: 'numeric' });
---
<div class="updates-list">{updates.map((item, index) => (
  <a href={item.href} style={`--update-accent: ${item.accent ?? 'var(--teal)'}`}>
    <span class="index">[{String(index + 1).padStart(2, '0')}]</span><span class="update-copy"><small>{item.kind.toLowerCase()}::updated</small><strong>{item.title}</strong><span>{item.description}</span></span><time datetime={item.date.toISOString()}>{formatter.format(item.date)}</time>
  </a>
))}</div>
<style>
  .updates-list { border-top: 1px solid var(--line); }
  a { min-height: 104px; display: grid; grid-template-columns: 52px minmax(0, 1fr) auto; align-items: center; gap: 1rem; color: var(--ink); border-bottom: 1px solid var(--line); text-decoration: none; }
  a:hover strong { color: var(--update-accent); }
  .index { color: var(--update-accent); font-family: var(--font-mono); font-size: .68rem; font-weight: 800; }
  .update-copy small, .update-copy strong, .update-copy > span { display: block; }
  .update-copy small { color: var(--update-accent); font-family: var(--font-mono); font-size: .58rem; font-weight: 750; }
  .update-copy strong { margin: .22rem 0; font-family: var(--font-sans); font-size: 1.08rem; }
  .update-copy > span { color: var(--muted); font-size: .77rem; }time { color: var(--muted); font-family: var(--font-mono); font-size: .63rem; }
  @media (max-width: 540px) { a { grid-template-columns: 42px minmax(0, 1fr); } time { display: none; } }
</style>
