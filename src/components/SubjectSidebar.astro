---
import type { CollectionEntry } from 'astro:content';
import { getLessonPath, groupLessonsByModule, groupLessonsBySection } from '../lib/content';
interface Props { subject: CollectionEntry<'subjects'>; lessons: CollectionEntry<'lessons'>[]; currentId?: string; }
const { subject, lessons, currentId } = Astro.props;
const hasSections = subject.data.sections.length > 0;
const sectionGroups = groupLessonsBySection(subject, lessons);
const moduleGroups = groupLessonsByModule(lessons);
const hasModules = moduleGroups.some((group) => group.module);
---
<nav class="subject-sidebar" aria-label={`${subject.data.title} lessons`}>
  <a class="subject-home" href={`/notes/${subject.data.slug}/`}><span>{subject.data.icon}</span><strong>{subject.data.title}</strong></a>
  {hasSections ? sectionGroups.map((section) => section.lessons.length > 0 && <section><h3>{section.title}</h3>{groupLessonsByModule(section.lessons).map((group) => <div class="lesson-group">{group.module && <h4>{group.module}</h4>}<ul>{group.lessons.map((lesson) => <li><a class:list={{ active: lesson.id === currentId }} href={getLessonPath(lesson)} aria-current={lesson.id === currentId ? 'page' : undefined}>{lesson.data.title}</a></li>)}</ul></div>)}</section>) : hasModules ? moduleGroups.map((group) => <section>{group.module && <h3>{group.module}</h3>}<ul>{group.lessons.map((lesson) => <li><a class:list={{ active: lesson.id === currentId }} href={getLessonPath(lesson)} aria-current={lesson.id === currentId ? 'page' : undefined}>{lesson.data.title}</a></li>)}</ul></section>) : <ul class="direct-lessons">{lessons.map((lesson) => <li><a class:list={{ active: lesson.id === currentId }} href={getLessonPath(lesson)} aria-current={lesson.id === currentId ? 'page' : undefined}>{lesson.data.title}</a></li>)}</ul>}
</nav>
<style>
  .subject-sidebar { --subject-accent: var(--teal); font-size: .76rem; }
  .subject-home { padding-bottom: 1rem; display: flex; align-items: center; gap: .65rem; border-bottom: 1px solid var(--line); color: var(--ink); text-decoration: none; }
  .subject-home span { width: 32px; height: 32px; display: grid; place-items: center; color: white; border-radius: var(--radius-sm); background: var(--subject-accent); font-family: var(--font-mono); font-size: .6rem; font-weight: 800; }
  .subject-home strong { font-family: var(--font-mono); font-size: .82rem; }
  section { margin-top: 1.25rem; }h3 { margin: 0 0 .55rem; color: var(--muted); font-family: var(--font-mono); font-size: .58rem; letter-spacing: .06em; text-transform: lowercase; }
  .lesson-group + .lesson-group { margin-top: .8rem; }h4 { margin: 0 0 .3rem .6rem; color: var(--muted); font-family: var(--font-mono); font-size: .52rem; font-weight: 650; text-transform: lowercase; }
  .direct-lessons { margin-top: 1rem; }
  ul { padding: 0; margin: 0; display: grid; gap: .2rem; list-style: none; }
  li a { padding: .45rem .6rem; display: block; border-left: 2px solid transparent; color: var(--ink-soft); text-decoration: none; }
  li a:hover, li a.active { color: var(--subject-accent); border-left-color: var(--subject-accent); background: color-mix(in srgb, var(--subject-accent) 8%, transparent); }
</style>
