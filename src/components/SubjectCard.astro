---
import type { CollectionEntry } from 'astro:content';
interface Props { subject: CollectionEntry<'subjects'>; lessonCount?: number; }
const { subject, lessonCount = 0 } = Astro.props;
---
<a class="subject-card" href={`/notes/${subject.data.slug}/`} style={`--subject-accent: ${subject.data.accent}`}>
  <span class="subject-icon" aria-hidden="true">{subject.data.icon ?? subject.data.title.slice(0, 2)}</span>
  <div class="subject-copy"><span class="status">{subject.data.status}</span><h3>{subject.data.title}</h3><p>{subject.data.description}</p></div>
  <div class="subject-meta"><span>{subject.data.sections.length} sections</span><span>{lessonCount} lessons</span><strong aria-hidden="true">↗</strong></div>
</a>
<style>
  .subject-card { min-height: 310px; padding: 1.6rem; display: flex; flex-direction: column; color: var(--ink); border: 1px solid var(--line); border-radius: var(--radius-lg); background: var(--surface); box-shadow: var(--shadow-sm); text-decoration: none; transition: transform .2s ease, box-shadow .2s ease; }
  .subject-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-md); }
  .subject-icon { width: 52px; height: 52px; display: grid; place-items: center; color: white; border-radius: 50%; background: var(--subject-accent); font-family: var(--font-serif); font-weight: 700; }
  .subject-copy { margin-block: 2rem auto; }
  .status { color: var(--subject-accent); font-size: .65rem; font-weight: 850; letter-spacing: .13em; text-transform: uppercase; }
  h3 { margin: .45rem 0 .65rem; font-family: var(--font-serif); font-size: 1.8rem; font-weight: 500; }
  p { margin: 0; color: var(--ink-soft); font-size: .9rem; line-height: 1.65; }
  .subject-meta { padding-top: 1rem; display: flex; align-items: center; gap: .85rem; color: var(--muted); border-top: 1px solid var(--line); font-size: .72rem; }
  .subject-meta strong { margin-left: auto; color: var(--subject-accent); font-size: 1rem; }
</style>
