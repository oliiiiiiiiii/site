---
interface Props { columns?: number; caption?: string; }
const { columns = 2, caption } = Astro.props;
---
<figure class="image-grid-wrap"><div class="image-grid" style={`--image-columns: ${columns}`}><slot /></div>{caption && <figcaption>{caption}</figcaption>}</figure>
<style>
  .image-grid-wrap { margin-block: 2rem; }
  .image-grid { display: grid; grid-template-columns: repeat(var(--image-columns), minmax(0, 1fr)); gap: .8rem; }
  .image-grid :global(img), .image-grid :global(video) { width: 100%; height: 100%; min-height: 220px; object-fit: cover; border-radius: var(--radius-sm); }
  figcaption { margin-top: .65rem; color: var(--muted); font-family: var(--font-sans); font-size: .74rem; text-align: center; }
  @media (max-width: 620px) { .image-grid { grid-template-columns: 1fr; }.image-grid :global(img), .image-grid :global(video) { min-height: 0; } }
</style>
