<section class="hero">
  <div class="hero-copy">
    <span class="eyebrow">Oli's Blog</span>
    <div class="command" aria-hidden="true"><span>olivia@blog</span>:<b>~</b>$ cat motto.txt</div>
    <h1 aria-label="Be the master and the sculptor of yourself."><span data-type-speed="82">Be the master and the </span><em data-type-speed="82">sculptor of yourself.</em><i class="typing-cursor" aria-hidden="true"></i></h1>
    <p class="description">A place where I share my thoughts, projects, and experiences—from NTU CSIE courses and technical notes to everything else I feel like writing down.</p>
    <div class="hero-actions"><a class="button" href="/library/">cd library</a><a class="button button--ghost" href="/about/">cd about</a></div>
    <div class="hero-status" aria-label="Current status"><span><i></i> NTU CSIE student</span><span>author: Olivia</span></div>
  </div>

</section>

<style>
  .hero { min-height: calc(100vh - 72px); width: min(calc(100% - 3rem), var(--content-max)); margin-inline: auto; padding-block: clamp(4rem, 9vw, 7rem); display: flex; align-items: center; }
  .hero-copy { width: 100%; text-align: center; }
  .command { margin-top: 1.25rem; color: var(--muted); font-family: var(--font-mono); font-size: .68rem; }.command span { color: var(--teal); }.command b { color: var(--coral); }
  h1 { max-width: 1120px; min-height: 1.86em; margin: 1rem auto 1.5rem; font-size: clamp(3.5rem, 7.6vw, 7.8rem); font-weight: 790; letter-spacing: -.065em; line-height: .93; }
  h1 em { color: inherit; font-style: normal; font-weight: inherit; }
  .typing-cursor { width: .07em; height: .78em; margin-left: .08em; display: inline-block; vertical-align: .02em; background: var(--coral); animation: cursor-blink .8s steps(1) infinite; }
  .description { max-width: 880px; margin: 0 auto; color: var(--ink-soft); font-size: clamp(1rem, 1.5vw, 1.2rem); line-height: 1.75; }
  .hero-actions { margin-top: 2rem; display: flex; flex-wrap: wrap; justify-content: center; gap: .8rem; }
  .hero-status { margin-top: 1.6rem; display: flex; flex-wrap: wrap; justify-content: center; gap: .65rem 1.2rem; color: var(--muted); font-family: var(--font-mono); font-size: .62rem; }.hero-status span:first-child { color: var(--teal); }.hero-status i { width: 6px; height: 6px; display: inline-block; margin-right: .35rem; border-radius: 50%; background: currentColor; box-shadow: 0 0 8px currentColor; }
  @keyframes cursor-blink { 50% { opacity: 0; } }
  @media (prefers-reduced-motion: reduce) { .typing-cursor { animation: none; } }
  @media (max-width: 680px) { .hero { width: calc(100% - 2rem); padding-block: 3.5rem; } }
</style>

<script>
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const typedElements = [...document.querySelectorAll<HTMLElement>('[data-type-speed]')];

  if (!reduceMotion) {
    const originals = typedElements.map((element) => element.textContent ?? '');
    typedElements.forEach((element) => { element.textContent = ''; });

    const type = async (element: HTMLElement, text: string) => {
      const speed = Number(element.dataset.typeSpeed ?? 24);
      for (const character of text) {
        element.textContent += character;
        await new Promise((resolve) => window.setTimeout(resolve, speed));
      }
    };

    (async () => {
      for (let index = 0; index < typedElements.length; index += 1) {
        await type(typedElements[index], originals[index]);
        await new Promise((resolve) => window.setTimeout(resolve, index === 1 ? 260 : 0));
      }
    })();
  }
</script>
