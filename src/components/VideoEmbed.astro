---
interface Props { src: string; title: string; poster?: string; caption?: string; }
const { src, title, poster, caption } = Astro.props;
const remote = /^https?:\/\//.test(src) && !/\.(mp4|webm|ogg)(\?|$)/i.test(src);
---
<figure class="video-wrap"><div class="video-frame">{remote ? <iframe src={src} title={title} loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe> : <video src={src} title={title} poster={poster} controls preload="metadata"></video>}</div>{caption && <figcaption>{caption}</figcaption>}</figure>
<style>
  .video-wrap { margin-block: 2rem; }.video-frame { aspect-ratio: 16 / 9; overflow: hidden; border: 1px solid var(--line); border-radius: var(--radius-md); background: #0c151a; box-shadow: var(--shadow-sm); }
  iframe, video { width: 100%; height: 100%; display: block; border: 0; }figcaption { margin-top: .6rem; color: var(--muted); font-family: var(--font-sans); font-size: .74rem; text-align: center; }
</style>
