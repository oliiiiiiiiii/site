---
import SiteIcon from './SiteIcon.astro';
interface Props { currentPath: string; }
const { currentPath } = Astro.props;
const links = [
  { href: '/', label: '~/home', icon: 'home' },
  { href: '/library/', label: '~/library', icon: 'library' },
  { href: '/posts/', label: '~/posts', icon: 'posts' },
  { href: '/notes/', label: '~/notes', icon: 'notes' },
  { href: '/archive/', label: '~/archive', icon: 'archive' },
  { href: '/about/', label: '~/about', icon: 'about' },
] as const;
const isActive = (href: string) => href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---
<aside class="app-sidebar" id="app-sidebar" aria-label="Site navigation" data-sidebar>
  <div class="sidebar-inner">
    <a class="identity" href="/" aria-label="Oli's Blog home">
      <span class="identity-mark"><img src="/images/site/avatar.png" alt="" /></span>
      <span><strong>Oli's Blog</strong></span>
    </a>
    <nav class="primary-nav" aria-label="Primary">
      {links.map((link) => (
        <a class:list={[link.icon, { active: isActive(link.href) }]} href={link.href} aria-current={isActive(link.href) ? 'page' : undefined}>
          <SiteIcon name={link.icon} size={20} /><span>{link.label}</span>
        </a>
      ))}
    </nav>
    <div class="sidebar-note">
      <span>~/currently</span>
      <code><i>author</i>: Olivia</code>
      <code><i>school</i>: NTU CSIE</code>
      <code><i>status</i>: learning</code>
    </div>
    <div class="sidebar-footer"><span>astro@7</span><span class="online"><i></i> online</span></div>
  </div>
</aside>
<button class="sidebar-scrim" type="button" aria-label="Close navigation" data-sidebar-close></button>

<style>
  .app-sidebar { position: fixed; z-index: 40; inset: 0 auto 0 0; width: 260px; padding: 1.1rem; background: color-mix(in srgb, var(--surface) 94%, var(--teal)); border-right: 1px solid var(--line); }
  .sidebar-inner { height: 100%; display: flex; flex-direction: column; }
  .identity { padding: .65rem .5rem 1.35rem; display: flex; align-items: center; gap: .8rem; color: var(--ink); text-decoration: none; border-bottom: 1px solid var(--line); }
  .identity-mark { width: 44px; height: 44px; display: block; flex: 0 0 auto; overflow: hidden; border: 1px solid var(--line-strong); border-radius: 50%; background: var(--surface-2); box-shadow: 3px 3px 0 color-mix(in srgb, var(--teal) 30%, transparent); }.identity-mark img { width: 100%; height: 100%; display: block; object-fit: cover; }
  .identity strong { display: block; }
  .identity strong { font-family: var(--font-mono); font-size: 1.3rem; }
  .primary-nav { padding-block: 1.5rem; display: grid; gap: .3rem; }
  .primary-nav a { min-height: 44px; padding: .65rem .75rem; display: flex; align-items: center; gap: .75rem; border-radius: var(--radius-sm); color: var(--ink-soft); text-decoration: none; font-family: var(--font-mono); font-size: .75rem; font-weight: 650; }
  .primary-nav a:hover { color: var(--ink); background: color-mix(in srgb, var(--surface) 65%, transparent); }
  .primary-nav a.active { color: var(--accent-ink); background: var(--teal); box-shadow: 3px 3px 0 color-mix(in srgb, var(--teal) 30%, transparent); }
  .primary-nav a.notes.active { color: var(--accent-ink); background: var(--teal); }
  .sidebar-note { margin-top: auto; padding: 1rem; display: grid; gap: .35rem; border: 1px solid var(--line); border-radius: var(--radius-sm); background: var(--paper); font-family: var(--font-mono); }
  .sidebar-note span { margin-bottom: .3rem; color: var(--coral); font-size: .64rem; font-weight: 800; }
  .sidebar-note code { color: var(--muted); font-size: .67rem; }.sidebar-note code i { color: var(--teal); font-style: normal; }
  .sidebar-footer { padding: 1.1rem .4rem .2rem; display: flex; justify-content: space-between; color: var(--muted); font-family: var(--font-mono); font-size: .61rem; }.online { display: flex; align-items: center; gap: .35rem; }.online i { width: 6px; height: 6px; border-radius: 50%; background: var(--teal); box-shadow: 0 0 8px var(--teal); }
  .sidebar-scrim { display: none; }
  @media (max-width: 1020px) {
    .app-sidebar { transform: translateX(-105%); transition: transform .24s ease; box-shadow: var(--shadow-md); }
    :global(body.sidebar-open) .app-sidebar { transform: translateX(0); }
    .sidebar-scrim { position: fixed; z-index: 35; inset: 0; width: 100%; height: 100%; border: 0; background: rgba(10, 22, 29, .48); }
    :global(body.sidebar-open) .sidebar-scrim { display: block; }
  }
</style>
