---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ModuleList from '../components/ModuleList.astro';
import RecentUpdateList from '../components/RecentUpdateList.astro';
import { getLessonPath, groupLessonsBySection } from '../lib/content';

interface Props { subject: CollectionEntry<'subjects'>; lessons: CollectionEntry<'lessons'>[]; }
const { subject, lessons } = Astro.props;
const groups = groupLessonsBySection(subject, lessons);
const hasSections = subject.data.sections.length > 0;
const modules = [...new Set(lessons.map((lesson) => lesson.data.module).filter((module): module is string => Boolean(module)))];
const hasModules = modules.length > 0;
const recent = [...lessons].sort((a, b) => b.data.updated.valueOf() - a.data.updated.valueOf()).slice(0, 4).map((lesson) => ({ href: getLessonPath(lesson), title: lesson.data.title, description: lesson.data.description, date: lesson.data.updated, kind: lesson.data.section ?? lesson.data.module ?? subject.data.slug, accent: 'var(--teal)' }));
---
<BaseLayout title={`${subject.data.title} notes — Oli's Blog`} description={subject.data.description}>
  <header class="subject-hero">
    <div class="page-shell"><Breadcrumbs items={[{ label: 'Notes', href: '/notes/' }, { label: subject.data.title }]} /><div class="subject-title-row"><span class="subject-icon">{subject.data.icon}</span><div><h1>{subject.data.title}</h1></div></div><div class="subject-stats">{hasSections && <span><strong>{subject.data.sections.length}</strong> sections</span>}{hasModules && <span><strong>{modules.length}</strong> modules</span>}<span><strong>{lessons.length}</strong> lessons</span></div></div>
  </header>
  <div class="page-shell subject-body">
    <section>
      {hasSections ? (
        <div class="section-tabs" data-section-tabs>
          <aside class="section-selector">
            <span class="selector-label">SECTION</span>
            <div class="tab-list" role="tablist" aria-label={`${subject.data.title} sections`}>
              {groups.map((group, index) => <button class:list={{ active: index === 0 }} type="button" role="tab" id={`tab-${subject.data.slug}-${group.id}`} aria-controls={`panel-${subject.data.slug}-${group.id}`} aria-selected={index === 0 ? 'true' : 'false'} data-section-tab={group.id}><span>{String(index + 1).padStart(2, '0')}</span>{group.title}</button>)}
            </div>
          </aside>
          <div class="section-panels">
            {groups.map((group, index) => <section class="section-panel" role="tabpanel" id={`panel-${subject.data.slug}-${group.id}`} aria-labelledby={`tab-${subject.data.slug}-${group.id}`} data-section-panel={group.id} hidden={index !== 0}><ModuleList lessons={group.lessons} /></section>)}
          </div>
        </div>
      ) : (
        <div class="flat-lessons"><ModuleList lessons={lessons} /></div>
      )}
    </section>
    {recent.length > 0 && <section class="recent"><div class="section-heading"><div><span class="eyebrow">Latest changes</span><h2 class="section-title">Recently updated</h2></div></div><RecentUpdateList updates={recent} /></section>}
  </div>
</BaseLayout>
<style>
  .subject-hero { --subject-accent: var(--teal); padding-block: clamp(3rem, 8vw, 6rem); border-bottom: 1px solid var(--line); background: linear-gradient(120deg, color-mix(in srgb, var(--subject-accent) 12%, var(--paper)), var(--paper) 65%); }
  .subject-body { --subject-accent: var(--teal); }
  .subject-title-row { margin-top: 2rem; display: grid; grid-template-columns: 90px minmax(0, 1fr); align-items: start; gap: 1.6rem; }
  .subject-icon { width: 90px; height: 90px; display: grid; place-items: center; color: white; border-radius: var(--radius-sm); background: var(--subject-accent); font-family: var(--font-mono); font-size: 1.3rem; font-weight: 700; box-shadow: 6px 6px 0 color-mix(in srgb, var(--subject-accent) 24%, transparent); }
  h1 { margin: .35rem 0 .75rem; font-family: var(--font-sans); font-size: clamp(3rem, 7vw, 5.5rem); font-weight: 780; letter-spacing: -.055em; line-height: .95; }
  .subject-stats { margin-top: 2.4rem; padding-top: 1.2rem; display: flex; gap: 2rem; border-top: 1px solid var(--line); color: var(--muted); font-family: var(--font-mono); font-size: .65rem; }
  .subject-stats strong { color: var(--subject-accent); font-size: 1.2rem; }
  .subject-body { padding-top: clamp(3rem, 6vw, 5rem); }
  .flat-lessons { max-width: 820px; }
  .section-tabs { max-width: 980px; display: grid; grid-template-columns: 190px minmax(0, 1fr); align-items: start; gap: clamp(2rem, 5vw, 5rem); }
  .section-selector { position: sticky; top: 2rem; min-width: 0; }
  .selector-label { display: block; margin: 0 0 .65rem .35rem; color: var(--muted); font-family: var(--font-mono); font-size: .6rem; font-weight: 800; letter-spacing: .14em; }
  .tab-list { width: 100%; padding: .35rem; display: flex; flex-direction: column; gap: .25rem; overflow: hidden; border: 1px solid var(--line); border-radius: .6rem; background: color-mix(in srgb, var(--surface-2) 70%, var(--surface)); box-shadow: var(--shadow-sm); }
  .tab-list::-webkit-scrollbar { display: none; }
  .tab-list button { width: 100%; min-height: 44px; padding: .45rem .8rem .45rem .5rem; display: inline-flex; align-items: center; gap: .55rem; color: var(--ink-soft); border: 0; border-radius: .38rem; background: transparent; cursor: pointer; font-family: var(--font-sans); font-size: .82rem; font-weight: 720; text-align: left; transition: color .18s ease, background .18s ease, box-shadow .18s ease, transform .18s ease; }
  .tab-list button span { width: 27px; height: 27px; display: grid; place-items: center; color: var(--muted); border: 1px solid var(--line); border-radius: .3rem; background: var(--surface); font-family: var(--font-mono); font-size: .56rem; font-weight: 800; transition: color .18s ease, border-color .18s ease, background .18s ease; }
  .tab-list button:hover { color: var(--subject-accent); background: color-mix(in srgb, var(--subject-accent) 7%, transparent); transform: translateY(-1px); }
  .tab-list button:hover span { color: var(--subject-accent); border-color: color-mix(in srgb, var(--subject-accent) 45%, var(--line)); }
  .tab-list button.active { color: var(--ink); background: color-mix(in srgb, var(--subject-accent) 14%, var(--surface)); box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--subject-accent) 42%, transparent), 0 3px 10px color-mix(in srgb, var(--subject-accent) 12%, transparent); transform: none; }
  .tab-list button.active span { color: var(--accent-ink); border-color: var(--subject-accent); background: var(--subject-accent); }
  .section-panels { min-width: 0; }
  .section-panel[hidden] { display: none; }
  .recent { margin-top: clamp(4rem, 8vw, 7rem); }
  @media (max-width: 700px) { .section-tabs { grid-template-columns: 1fr; gap: 1.25rem; }.section-selector { position: static; }.tab-list { flex-direction: row; overflow-x: auto; scrollbar-width: none; }.tab-list button { width: auto; flex: 0 0 auto; } }
  @media (max-width: 600px) { .subject-title-row { grid-template-columns: 1fr; }.subject-icon { width: 68px; height: 68px; }.subject-stats { flex-wrap: wrap; gap: 1rem 1.5rem; } }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-section-tabs]').forEach((tabs) => {
    const buttons = [...tabs.querySelectorAll<HTMLButtonElement>('[data-section-tab]')];
    const panels = [...tabs.querySelectorAll<HTMLElement>('[data-section-panel]')];

    buttons.forEach((button) => button.addEventListener('click', () => {
      const section = button.dataset.sectionTab;
      buttons.forEach((item) => {
        const active = item === button;
        item.classList.toggle('active', active);
        item.setAttribute('aria-selected', String(active));
      });
      panels.forEach((panel) => { panel.hidden = panel.dataset.sectionPanel !== section; });
    }));
  });
</script>
