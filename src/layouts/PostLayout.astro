---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PreviousNext from '../components/PreviousNext.astro';
import TableOfContents from '../components/TableOfContents.astro';
import TagList from '../components/TagList.astro';
import { formatDate, getPostPath } from '../lib/content';
import '../styles/prose.css';

interface Heading { depth: number; slug: string; text: string; }
interface Props {
  post: CollectionEntry<'posts'>;
  headings: Heading[];
  previous?: CollectionEntry<'posts'>;
  next?: CollectionEntry<'posts'>;
}
const { post, headings, previous, next } = Astro.props;
---
<BaseLayout title={`${post.data.title} — Olí's Blog`} description={post.data.description} image={post.data.cover}>
  <article class="post-shell page-shell">
    <header class="post-header">
      <Breadcrumbs items={[{ label: 'Posts', href: '/posts/' }, { label: post.data.title }]} />
      <h1>{post.data.title}</h1>
      <p>{post.data.description}</p>
      <div class="post-meta"><time datetime={post.data.published.toISOString()}>Published {formatDate(post.data.published)}</time>{post.data.updated && <time datetime={post.data.updated.toISOString()}>Updated {formatDate(post.data.updated)}</time>}</div>
      <TagList tags={post.data.tags} />
    </header>
    {post.data.cover && <figure class="post-cover"><img src={post.data.cover} alt="" /></figure>}
    <div class="post-grid">
      <div class="prose"><slot /></div>
      <aside class="post-toc"><TableOfContents headings={headings} /></aside>
    </div>
    <PreviousNext
      previous={previous ? { href: getPostPath(previous), title: previous.data.title, label: 'Older post' } : undefined}
      next={next ? { href: getPostPath(next), title: next.data.title, label: 'Newer post' } : undefined}
    />
  </article>
</BaseLayout>
<style>
  .post-shell { max-width: 1050px; padding-top: clamp(3rem, 7vw, 6rem); }
  .post-header { max-width: 820px; margin-inline: auto; text-align: center; }
  .post-header :global(.breadcrumbs ol) { justify-content: center; }
  h1 { margin: 1.4rem 0 1rem; font-family: var(--font-sans); font-size: clamp(2.7rem, 7vw, 5.2rem); font-weight: 770; letter-spacing: -.055em; line-height: 1; }
  .post-header > p { max-width: 650px; margin: 0 auto 1.2rem; color: var(--ink-soft); font-size: 1.1rem; line-height: 1.7; }
  .post-meta { margin-bottom: 1rem; display: flex; justify-content: center; flex-wrap: wrap; gap: .4rem 1.2rem; color: var(--muted); font-family: var(--font-mono); font-size: .65rem; }
  .post-header :global(.tag-list) { justify-content: center; }
  .post-cover { margin: clamp(2.5rem, 6vw, 5rem) 0; overflow: hidden; aspect-ratio: 16 / 8; border-radius: var(--radius-lg); background: var(--surface-2); box-shadow: var(--shadow-md); }
  .post-cover img { width: 100%; height: 100%; object-fit: cover; }
  .post-grid { max-width: 920px; margin-inline: auto; display: grid; grid-template-columns: minmax(0, 700px) 170px; align-items: start; justify-content: center; gap: 3rem; }
  .post-toc { position: sticky; top: 2rem; padding-top: .3rem; }
  .post-shell > :global(.previous-next) { max-width: 920px; margin-inline: auto; }
  @media (max-width: 820px) { .post-grid { grid-template-columns: 1fr; }.post-toc { display: none; }.post-cover { border-radius: var(--radius-md); } }
</style>
