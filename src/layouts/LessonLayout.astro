---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PreviousNext from '../components/PreviousNext.astro';
import SubjectSidebar from '../components/SubjectSidebar.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { formatDate, getLessonPath } from '../lib/content';
import '../styles/prose.css';

interface Heading { depth: number; slug: string; text: string; }
interface Props { subject: CollectionEntry<'subjects'>; lesson: CollectionEntry<'lessons'>; lessons: CollectionEntry<'lessons'>[]; headings: Heading[]; previous?: CollectionEntry<'lessons'>; next?: CollectionEntry<'lessons'>; }
const { subject, lesson, lessons, headings, previous, next } = Astro.props;
---
<BaseLayout title={`${lesson.data.title} — ${subject.data.title}`} description={lesson.data.description}>
  <div class="lesson-shell" style={`--subject-accent: ${subject.data.accent}`}>
    <article class="lesson-main">
      <Breadcrumbs items={[{ label: 'Subjects', href: '/notes/' }, { label: subject.data.title, href: `/notes/${subject.data.slug}/` }, { label: lesson.data.title }]} />
      <header><span>{lesson.data.module}</span><h1>{lesson.data.title}</h1><p>{lesson.data.description}</p><div class="lesson-meta"><time datetime={lesson.data.updated.toISOString()}>Updated {formatDate(lesson.data.updated)}</time><span>{lesson.data.section}</span></div></header>
      <details class="mobile-outline"><summary>Browse lesson outline</summary><div><SubjectSidebar subject={subject} lessons={lessons} currentId={lesson.id} /><TableOfContents headings={headings} /></div></details>
      <div class="prose"><slot /></div>
      <PreviousNext previous={previous ? { href: getLessonPath(previous), title: previous.data.title, label: 'Previous lesson' } : undefined} next={next ? { href: getLessonPath(next), title: next.data.title, label: 'Next lesson' } : undefined} />
    </article>
    <aside class="lesson-nav"><SubjectSidebar subject={subject} lessons={lessons} currentId={lesson.id} /></aside>
    <aside class="lesson-toc"><TableOfContents headings={headings} /></aside>
  </div>
</BaseLayout>
<style>
  .lesson-shell { width: min(calc(100% - 3rem), 1320px); margin: 0 auto; padding-top: 3rem; display: grid; grid-template-columns: 210px minmax(0, 720px) 170px; grid-template-areas: 'nav main toc'; justify-content: center; align-items: start; gap: clamp(1.5rem, 3vw, 3.5rem); }
  .lesson-main { grid-area: main; min-width: 0; }
  .lesson-main header { margin: 1.8rem 0 3rem; padding-bottom: 2rem; border-bottom: 1px solid var(--line); }
  .lesson-main header > span { color: var(--subject-accent); font-family: var(--font-mono); font-size: .62rem; font-weight: 800; letter-spacing: .08em; text-transform: lowercase; }
  h1 { margin: .5rem 0 .8rem; font-family: var(--font-sans); font-size: clamp(2.6rem, 6vw, 4.5rem); font-weight: 770; letter-spacing: -.05em; line-height: 1; }
  header p { margin: 0; color: var(--ink-soft); font-size: 1.05rem; line-height: 1.65; }
  .lesson-meta { margin-top: 1rem; display: flex; gap: 1rem; color: var(--muted); font-family: var(--font-mono); font-size: .62rem; text-transform: lowercase; }
  .lesson-nav { position: sticky; top: 1.5rem; grid-area: nav; max-height: calc(100vh - 3rem); overflow-y: auto; padding-right: .5rem; }.lesson-toc { position: sticky; top: 1.5rem; grid-area: toc; }
  .mobile-outline { display: none; }
  @media (max-width: 1160px) { .lesson-shell { grid-template-columns: 190px minmax(0, 720px); grid-template-areas: 'nav main'; }.lesson-toc { display: none; } }
  @media (max-width: 820px) { .lesson-shell { width: min(calc(100% - 2rem), 720px); grid-template-columns: 1fr; grid-template-areas: 'main'; }.lesson-nav { display: none; }.mobile-outline { margin: 0 0 2rem; display: block; border: 1px solid var(--line); border-radius: var(--radius-sm); background: var(--surface); }.mobile-outline summary { padding: .85rem 1rem; color: var(--subject-accent); cursor: pointer; font-weight: 750; }.mobile-outline > div { padding: 0 1rem 1rem; display: grid; gap: 1.5rem; } }
</style>
